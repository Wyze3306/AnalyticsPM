<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MCPE Analytics - Connexion</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: linear-gradient(135deg, #0c0a1a 0%, #1a1040 50%, #0c0a1a 100%);
      color: #f0ecff;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }
    .login-container {
      width: 100%;
      max-width: 400px;
      padding: 20px;
    }
    .login-card {
      background: rgba(26, 21, 53, 0.8);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(139, 92, 246, 0.2);
      border-radius: 20px;
      padding: 48px 36px;
      box-shadow: 0 8px 60px rgba(0, 0, 0, 0.5), 0 0 40px rgba(139, 92, 246, 0.08);
      text-align: center;
    }
    .logo {
      width: 56px; height: 56px;
      background: linear-gradient(135deg, #8b5cf6, #ec4899);
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      margin: 0 auto 20px;
      box-shadow: 0 4px 25px rgba(139, 92, 246, 0.4);
    }
    h1 {
      font-size: 22px;
      font-weight: 800;
      background: linear-gradient(135deg, #8b5cf6, #ec4899);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 6px;
    }
    .subtitle {
      font-size: 13px;
      color: #7b6fa0;
      margin-bottom: 32px;
    }
    .form-group {
      margin-bottom: 20px;
      text-align: left;
    }
    label {
      display: block;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      color: #7b6fa0;
      margin-bottom: 8px;
    }
    input[type="password"] {
      width: 100%;
      padding: 14px 16px;
      background: rgba(13, 10, 26, 0.6);
      border: 1px solid rgba(139, 92, 246, 0.25);
      border-radius: 12px;
      color: #f0ecff;
      font-size: 15px;
      font-family: inherit;
      outline: none;
      transition: all 0.25s;
    }
    input[type="password"]:focus {
      border-color: #8b5cf6;
      box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.15);
    }
    input[type="password"]::placeholder { color: #4a4070; }
    button {
      width: 100%;
      padding: 14px;
      background: linear-gradient(135deg, #8b5cf6, #ec4899);
      border: none;
      border-radius: 12px;
      color: white;
      font-size: 14px;
      font-weight: 700;
      font-family: inherit;
      cursor: pointer;
      transition: all 0.25s;
      box-shadow: 0 4px 20px rgba(139, 92, 246, 0.35);
    }
    button:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 30px rgba(139, 92, 246, 0.5);
    }
    button:active { transform: translateY(0); }
    .error {
      background: rgba(248, 113, 113, 0.1);
      border: 1px solid rgba(248, 113, 113, 0.3);
      color: #f87171;
      padding: 10px 14px;
      border-radius: 10px;
      font-size: 13px;
      font-weight: 600;
      margin-bottom: 20px;
    }
    .bg-glow {
      position: fixed;
      width: 400px; height: 400px;
      border-radius: 50%;
      filter: blur(120px);
      opacity: 0.15;
      pointer-events: none;
    }
    .bg-glow.purple { background: #8b5cf6; top: -100px; left: -100px; }
    .bg-glow.pink { background: #ec4899; bottom: -100px; right: -100px; }
  </style>
</head>
<body>
  <div class="bg-glow purple"></div>
  <div class="bg-glow pink"></div>
  <div class="login-container">
    <div class="login-card">
      <div class="logo">&#9670;</div>
      <h1>Analytics</h1>
      <p class="subtitle">Connectez-vous au panel</p>
      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>
      <form method="POST" action="/login">
        <div class="form-group">
          <label>Mot de passe</label>
          <input type="password" name="password" placeholder="Entrez le mot de passe" autofocus required>
        </div>
        <button type="submit">Se connecter</button>
      </form>
    </div>
  </div>
</body>
</html>
